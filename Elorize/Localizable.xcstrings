      }
    },
    "%lld%%" : {
      "comment" : "A label displaying the percentage of questions the user answered correctly in a quiz. The argument is the percentage of correct answers.",
      "isCommentAutoGenerated" : true
    },
    "• Correct answer: +5 XP" : {
      "comment" : "A tip for earning XP by answering questions correctly.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Korrekte Antwort: +5 XP"
          }
        }
      }
    },
    "• Example: %lld correct answers or a mix of correct/incorrect" : {
      "comment" : "A tip for the next level of the app, suggesting how many correct answers are needed to reach the next level. The argument is the number of correct answers needed to reach the next level.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Beispiel: %lld korrekte Antworten oder eine Mischung aus korrekt/inkorrekt"
          }
        }
      }
    },
    "• Level up: Every 100 XP, your level increases and XP resets within the new level" : {
      "comment" : "A tip for earning XP that mentions level-ups.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Ins nächste Level aufsteigen: Immer nach 100 XP steigt man in das nächste Level auf und der XP Balken beginnt von vorne"
          }
        }
      }
    },
    "• Study regularly: Consistent sessions help you level up faster" : {
      "comment" : "A tip for studying that emphasizes the importance of regular study sessions.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Lerne regelmäßig: Bleib dabei um schneller aufzusteigen"
          }
        }
      }
    },
    "• Wrong answer: +1 XP (for the attempt)" : {
      "comment" : "A tip for earning XP by getting an answer wrong.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Falsche Antwort: +1 XP (für den Versuch)"
