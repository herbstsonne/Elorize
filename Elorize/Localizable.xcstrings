      "comment" : "A label indicating that a user has marked a flashcard as \"wrong\".",
      "isCommentAutoGenerated" : true
    },
    "%lld / %lld" : {
      "comment" : "Displays the user's score out of the total number of questions, along with a percentage and a message describing the user's performance.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld"
