      "comment" : "A label showing the number of cards associated with a particular patient. The argument is the number of cards for that patient.",
      "isCommentAutoGenerated" : true
    },
    "%lld minutes" : {
      "comment" : "A text label displaying the duration of a flower's effect in minutes. The argument is the duration of the flower's effect in minutes.",
      "isCommentAutoGenerated" : true
    },
